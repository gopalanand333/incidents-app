{
    "name": "incidents",
    "version": "1.0.0",
    "dependencies": {
        "@cap-js/telemetry": "^0.0.1-alpha.1",
        "@sap/cds": ">=7",
        "@sap/cds-hana": "^2",
        "@sap/xssec": "^3",
        "express": "^4",
        "passport": "^0"
    },
    "devDependencies": {
        "@cap-js/sqlite": "^1.0.1",
        "@sap/cds-dk": "^7",
        "@sap/ux-specification": "^1.108.4",
        "axios": "^1.4.0",
        "chai": "^4.3.7",
        "chai-as-promised": "^7.1.1",
        "chai-subset": "^1.6.0",
        "jest": "^29.5.0",
        "rimraf": "^3.0.2"
    },
    "scripts": {
        "watch": "cds watch",
        "start": "cds-serve",
        "test": "npx jest --silent",
        "undeploy": "cf undeploy incidents --delete-services --delete-service-keys --delete-service-brokers",
        "build": "rimraf resources mta_archives && mbt build --mtar archive",
        "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
    },
    "private": true,
    "sapux": [
        "app/incidents"
    ],
    "cds": {
        "log": {
            "levels": {
                "cds": "trace",
                "hana": "trace"
            }
        },
        "requires": {
            "incidents-app": {
                "model": "@capire/incidents"
            },
            "[production]": {
                "db": {
                    "kind": "hana-cloud"
                },
                "auth": {
                    "kind": "xsuaa"
                },
                "approuter": {
                    "kind": "cloudfoundry"
                }
            },
            "[development]": {
                "auth": {
                    "kind": "mocked",
                    "users": {
                        "incident.support@tester.sap.com": {
                            "password": "initial",
                            "roles": [
                                "support"
                            ]
                        },
                        "alice": {
                            "roles": [
                                "support",
                                "admin"
                            ]
                        },
                        "bob": {
                            "roles": [
                                "support"
                            ]
                        }
                    }
                }
            },
            "db": {
                "kind": "sql"
            }
        }
    }
}
